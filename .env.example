# MySQL Configuration

# Application Database Configuration (for connection from Next.js)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=stneoc
# DB_PORT=3306

# # API URLs
# NEXT_PUBLIC_API_URL=http://localhost:3000

# ThaiID OAuth Configuration (DOPA)
# CALLBACK=http://localhost:3000/api/auth/thaiid/callback
# APIKEY=your_thaiid_apikey_here
# CLIENT_ID=your_thaiid_client_id_here
# CLIENT_SECRET=your_thaiid_client_secret_here

# # GISTDA API
# GISTDA_API_KEY=your_gistda_api_key_here

# Google Gemini API
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot for officer notifications
# TELEGRAM_BOT_TOKEN=123456:telegram_bot_token
# TELEGRAM_BOT_USERNAME=your_bot_username
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
# Comma-separated chat IDs for citizen help request notifications.
# Supports personal chat IDs, group IDs, and supergroup IDs such as -1001234567890.
# TELEGRAM_HELP_NOTIFY_CHAT_IDS=123456789,-1001234567890
# Separate recipients for authentication/security anomaly alerts.
# If omitted, TELEGRAM_NOTIFY_CHAT_IDS or TELEGRAM_HELP_NOTIFY_CHAT_IDS is used.
# TELEGRAM_SECURITY_CHAT_IDS=123456789,-1001234567890

# Secret Key for Encryption (IMPORTANT: Use strong random string in production)
# Generate: openssl rand -base64 32
SECRET_KEY=your_strong_secret_key_here
