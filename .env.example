# MySQL Configuration

# Application Database Configuration (for connection from Next.js)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=stneoc
DB_PORT=3306

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000

# ThaiID OAuth Configuration (DOPA)
CALLBACK=http://localhost:3000/api/auth/thaiid/callback
APIKEY=your_thaiid_apikey_here
CLIENT_ID=your_thaiid_client_id_here
CLIENT_SECRET=your_thaiid_client_secret_here

# GISTDA API
GISTDA_API_KEY=your_gistda_api_key_here

# Google Gemini API
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Secret Key for Encryption (IMPORTANT: Use strong random string in production)
# Generate: openssl rand -base64 32
SECRET_KEY=your_strong_secret_key_here
